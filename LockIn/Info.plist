<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- HealthKit usage descriptions — required for App Store / device install -->
	<key>NSHealthShareUsageDescription</key>
	<string>LockIn reads body weight, steps, and workout data from Apple Health to update your daily metrics and calorie calculations. No data is sent off-device.</string>

	<key>NSHealthUpdateUsageDescription</key>
	<string>LockIn can optionally write body weight measurements to Apple Health when you log a weigh-in.</string>

	<!-- MyNetDiary deep-link URL scheme must be whitelisted for canOpenURL() to work -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>mynetdiary</string>
	</array>

	<!-- Background modes: none needed — all notifications are local -->

	<!-- App Intents / Siri support -->
	<key>NSUserActivityTypes</key>
	<array>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER).openAntiBingeFlow</string>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER).markWeighIn</string>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER).showNightPlan</string>
	</array>

	<!-- Required iOS keys -->
	<key>UILaunchScreen</key>
	<dict/>

	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict/>
	</dict>

	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
